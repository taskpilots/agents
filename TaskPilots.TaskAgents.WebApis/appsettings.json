{
  "ConnectionStrings": {
    "TaskAgentsPostgres": "Host=127.0.0.1;Port=5432;Database=taskagents;Username=taskagents;Password=taskagents"
  },
  "TaskAgents": {
    "Data": {
      "Mode": "InMemory"
    },
    "OpenAi": {
      "BaseUrl": "https://api.openai.com/v1",
      "Model": "gpt-5-mini",
      "ApiKey": ""
    },
    "Mailbox": {
      "Enabled": false,
      "PollInterval": "00:00:30",
      "InboxAddress": "analysis@example.local"
    },
    "Webhook": {
      "Enabled": true,
      "SharedSecret": "development-secret"
    },
    "Storage": {
      "RootPath": "./data",
      "ArchivePath": "./data/archive"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
