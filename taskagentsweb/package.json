{
  "name": "taskagentsweb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "pnpm run copy-wwwroot",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "copy-wwwroot": "node ./scripts/copy-dist-to-wwwroot.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.30.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^2.1.8"
  }
}
